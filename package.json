{
  "name": "annotate",
  "version": "0.1.0",
  "description": "Privacy-first local document annotation in the browser, with vendored offline PDF and DOCX support and no runtime build or package installation.",
  "license": "Apache-2.0",
  "homepage": "https://annotate.readcloser.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/lfurze/annotate.git"
  },
  "bugs": {
    "url": "https://github.com/lfurze/annotate/issues"
  },
  "keywords": ["annotation", "pdf", "docx", "privacy", "local-first", "highlighter", "comments", "no-build"],
  "scripts": {
    "start": "python3 -m http.server 8777",
    "samples": "python3 test/make_samples.py",
    "test": "npm --prefix test test",
    "test:fast": "npm --prefix test run test:fast",
    "test:browser": "npm --prefix test run test:browser"
  },
  "dependencies": {},
  "private": true
}
